// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


// ======================
// Tabel Users & Roles
// ======================
model Users {
  id       Int     @id @default(autoincrement())
  username String
  email    String  @unique
  password String
  role_id  Int?

  role     Roles?  @relation(fields: [role_id], references: [id])
  admin    Admin[]
  rt       RT[]
}

model Roles {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  users       Users[]
}

// ======================
// Tabel Admin & RT
// ======================
model Admin {
  id           Int     @id @default(autoincrement())
  user_id      Int?
  nama_lengkap String
  no_hp        String?
  alamat       String?

  user         Users?  @relation(fields: [user_id], references: [id])
}

model RT {
  id_rt        Int     @id @default(autoincrement())
  user_id      Int?
  nomor_rt     Int
  nama_lengkap String
  no_hp        String?
  alamat       String?

  user         Users?      @relation(fields: [user_id], references: [id])
  penduduk     Penduduk[]
}

// ======================
// Tabel KK & Penduduk
// ======================
model KK {
  id_kk              Int       @id @default(autoincrement())
  no_kk              String    @unique
  kepala_keluarga_id Int       @unique
  alamat             String
  rt                 String
  rw                 String
  kode_pos           String?
  desa_kelurahan     String
  kecamatan          String
  kabupaten_kota     String
  provinsi           String

  kepala_keluarga    Penduduk  @relation("KepalaKeluarga", fields: [kepala_keluarga_id], references: [id_penduduk])
  anggota            Penduduk[] @relation("AnggotaKK")
}

model Penduduk {
  id_penduduk             Int        @id @default(autoincrement())
  nik                     String     @unique
  nama                    String
  password                String
  jenis_kelamin           JenisKelamin
  tanggal_lahir           DateTime
  alamat                  String
  no_rt                   Int?
  status_warga            StatusWarga? @default(tetap)
  id_kk                   Int?
  tempat_lahir            String
  agama                   String?
  pekerjaan               String?
  pendidikan_terakhir     String?
  gol_darah               GolDarah?
  status_perkawinan       StatusPerkawinan?
  tanggal_perkawinan      DateTime?
  hubungan_dalam_keluarga String?
  kewarganegaraan         String?   @default("WNI")
  no_paspor               String?   @default("-")
  no_kitap                String?   @default("-")
  nama_ayah               String?
  nama_ibu                String?

  rt                      RT?       @relation(fields: [no_rt], references: [id_rt])
  kk                      KK?       @relation("AnggotaKK", fields: [id_kk], references: [id_kk])
  kk_kepala               KK?       @relation("KepalaKeluarga")
  surat_pengajuan         SuratPengajuan[]
}

// ======================
// Tabel Surat Pengajuan
// ======================
model SuratPengajuan {
  id_surat            Int              @id @default(autoincrement())
  id_penduduk         Int
  jenis_surat         JenisSurat
  keterangan          String?
  tanggal_pengajuan   DateTime?        @default(now())
  tanggal_proses      DateTime?
  tanggal_pengambilan DateTime?
  status              StatusPengajuan? @default(Diajukan)

  penduduk            Penduduk         @relation(fields: [id_penduduk], references: [id_penduduk])
}

// ======================
// ENUMS
// ======================
enum JenisKelamin {
  laki_laki
  perempuan
}

enum StatusWarga {
  tetap
  kontrak
  kost
  lainnya
}

enum GolDarah {
  A
  B
  AB
  O
  Tidak_Tahu
}

enum StatusPerkawinan {
  Belum_Kawin
  Kawin
  Cerai_Hidup
  Cerai_Mati
}

enum JenisSurat {
  Surat_Pengantar
  Surat_Domisili
  Surat_Keterangan
  Surat_Usaha
  Surat_Pembuatan_KTP
}

enum StatusPengajuan {
  Diajukan
  Diproses
  Selesai
  Diambil
}