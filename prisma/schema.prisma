generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ======================
// Tabel Users & Roles
// ======================
model Users {
  id          String    @id @default(cuid())
  nomor_urut  Int       @default(0)
  nik         String    @unique
  kk          String?
  nama        String
  password    String
  username    String?   @unique

  upload      FileUploads[]

  role_id     String?
  penduduk    Penduduk? @relation("UserPenduduk")
  role        Roles?    @relation(fields: [role_id], references: [id])
  RT          RT[]
  Sesi       Sesi[]
  Akun       Account[]
}

model Sesi {
  id           String   @id @default(cuid())
  token_sesi   String   @unique
  penggunaId   String
  kadaluarsa   DateTime

  pengguna     Users    @relation(fields: [penggunaId], references: [id], onDelete: Cascade)
}

model TokenVerifikasi {
  identifier String
  token      String   @unique
  kadaluarsa DateTime

  @@unique([identifier, token])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String   // e.g. "credentials" | "oauth"
  provider          String   // e.g. "google" | "credentials"
  providerAccountId String   // ID unik dari provider (misal sub dari Google)
  access_token      String?  // token oauth (opsional)
  refresh_token     String?  // token oauth (opsional)
  expires_at        Int?     // kapan token oauth kadaluarsa

  user              Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Roles {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  users       Users[]
}

// ======================
// Tabel Admin & RT
// ======================
model RT {
  id_rt        String   @id @default(cuid())
  user_id      String?
  nomor_rt     Int
  nama_lengkap String
  no_hp        String?
  alamat       String?

  upload      FileUploads[]

  user         Users?      @relation(fields: [user_id], references: [id])
  penduduk     Penduduk[]
}

// ======================
// Tabel KK & Penduduk
// ======================
model KK {
  id_kk              String     @id @default(cuid())
  no_kk              String     @unique
  kepala_keluarga_id String?     @unique
  alamat             String?
  rt                 String?
  rw                 String?
  kode_pos           String?
  desa_kelurahan     String?
  kecamatan          String?
  kabupaten_kota     String?
  provinsi           String?

  kepala_keluarga    Penduduk?   @relation("KepalaKeluarga", fields: [kepala_keluarga_id], references: [id_penduduk])
  anggota            Penduduk[] @relation("AnggotaKK")
}

model SuratPengajuan {
  id_surat            String           @id @default(cuid())
  id_penduduk         String
  jenis_surat         JenisSurat
  keterangan          String?
  tanggal_pengajuan   DateTime?        @default(now())
  tanggal_proses      DateTime?
  tanggal_pengambilan DateTime?
  status              StatusPengajuan? @default(Diajukan)

  upload              FileUploads[]


  penduduk            Penduduk         @relation(fields: [id_penduduk], references: [id_penduduk])
}

model Penduduk {
  id_penduduk   String    @id @default(cuid())
  nik           String    @unique
  nama          String
  id_kk         String?
  user_id       String?   @unique

  user          Users?    @relation("UserPenduduk" ,fields: [user_id], references: [id])
  kk            KK?       @relation("AnggotaKK", fields: [id_kk], references: [id_kk])
  kk_kepala     KK?       @relation("KepalaKeluarga")
  id_rt         String?
  RT            RT?       @relation(fields: [id_rt], references: [id_rt])
  surat_pengajuan SuratPengajuan[]

  jenis_kelamin           JenisKelamin?
  tanggal_lahir           DateTime?
  alamat                  String?
  status_warga            StatusWarga?     @default(tetap)
  tempat_lahir            String?
  agama                   String?
  pekerjaan               String?
  pendidikan_terakhir     String?
  gol_darah               GolDarah?
  status_perkawinan       StatusPerkawinan?
  tanggal_perkawinan      DateTime?
  hubungan_dalam_keluarga String?
  kewarganegaraan         String?          @default("WNI")
  no_paspor               String?          @default("-")
  no_kitap                String?          @default("-")
  nama_ayah               String?
  nama_ibu                String?
}

model FileUploads {
  id          String   @id @default(cuid())
  user_id     String?
  surat_id    String?
  rt_id       String?
  jenis_file  JenisFile
  path        String   // URL atau lokasi file tersimpan
  uploaded_at DateTime @default(now())

  Users            Users?          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  SuratPengajuan   SuratPengajuan? @relation(fields: [surat_id], references: [id_surat], onDelete: Cascade)
  RT               RT?             @relation(fields: [rt_id], references: [id_rt], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}


// ======================
// ENUMS
// ======================

enum JenisFile {
  KTP
  KK
  SURAT
  LAINNYA
}


enum JenisKelamin {
  laki_laki
  perempuan
}

enum StatusWarga {
  tetap
  kontrak
  kost
  lainnya
}

enum GolDarah {
  A
  B
  AB
  O
  Tidak_Tahu
}

enum StatusPerkawinan {
  Belum_Kawin
  Kawin
  Cerai_Hidup
  Cerai_Mati
}

enum JenisSurat {
  Surat_Pengantar
  Surat_Domisili
  Surat_Keterangan
  Surat_Usaha
  Surat_Pembuatan_KTP
}

enum StatusPengajuan {
  Diajukan
  Diproses
  Selesai
  Diambil
}
